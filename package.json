{
  "name": "hawk-bridge",
  "version": "1.1.1",
  "description": "OpenClaw hook bridge to hawk Python memory system - autoCapture + autoRecall",
  "type": "module",
  "main": "src/index.ts",
  "dependencies": {
    "@lancedb/lancedb": "^0.26.2",
    "axios": "^1.15.0",
    "https-proxy-agent": "^9.0.0",
    "js-yaml": "^4.1.1",
    "openai": "^6.21.0",
    "pino": "^10.3.1",
    "prom-client": "^15.1.3",
    "proxy-agent": "^8.0.1"
  },
  "devDependencies": {
    "esbuild": "^0.27.4",
    "typescript": "^6.0.2"
  },
  "openclaw": {
    "compat": {
      "pluginApi": "1.0"
    },
    "extensions": [
      "./dist/index.js"
    ],
    "hooks": [
      "./dist/hooks/hawk-recall",
      "./dist/hooks/hawk-capture"
    ]
  },
  "scripts": {
    "build": "node scripts/build.js",
    "seed": "node dist/seed.js",
    "decay": "node dist/cli/decay.js",
    "verify": "node dist/cli/verify.js",
    "write": "node dist/cli/write.js",
    "read-source": "node dist/cli/read-source.js",
    "doctor": "node dist/cli/doctor.js"
  }
}
